# Postgres
DATABASE_URL=postgresql://pulse:pulse@localhost:5432/pulseboard
DB_POOL_MIN=2
DB_POOL_MAX=10

# Redis: ingest stream buffer
REDIS_BUFFER_URL=redis://localhost:6379/0

# Redis: rate limiter (separate logical DB locally; separate instance in prod)
REDIS_RATELIMIT_URL=redis://localhost:6379/1

# Stream / consumer group
EVENTS_STREAM=events
CONSUMER_GROUP=rollup-workers
CONSUMER_NAME=worker-1
STREAM_MAXLEN=1000000

# Worker batching (freshness vs write-amplification knob)
WORKER_BATCH_SIZE=500
WORKER_BLOCK_MS=500
WORKER_CLAIM_IDLE_MS=30000

# Rate limiting (per-IP sliding window)
RATELIMIT_REQUESTS=100
RATELIMIT_WINDOW_SECONDS=1

# Validation
PROPS_MAX_BYTES=8192

# Misc
DEFAULT_TENANT=default
LOG_LEVEL=INFO

# CORS — frontend origins allowed to call the API
CORS_ORIGINS=["http://localhost:3000"]
