{
  "name": "@pulseboard/backend",
  "version": "0.1.0",
  "private": true,
  "description": "Turborepo wrapper for the uv-managed Python backend",
  "scripts": {
    "dev": "uv run python -m uvicorn app.main:app --reload --port 8000",
    "worker": "uv run python -m worker.main",
    "build": "uv sync",
    "migrate": "uv run alembic upgrade head",
    "lint": "uv run ruff check .",
    "format": "uv run ruff format .",
    "test": "uv run pytest -m \"not integration\"",
    "test:integration": "uv run pytest -m integration"
  }
}
